# ===================
# Frontend (ctf-frontend)
# ===================
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_TERMINAL_URL=ws://localhost:3001

# ===================
# Backend (ctf-backend)
# ===================
JWT_SECRET=change-me-to-a-secure-32-char-secret
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===================
# Terminal (ctf-terminal)
# ===================
PORT=3001

# ===================
# Database (defaults set by docker-compose)
# ===================
# Uncomment to override docker-compose defaults:
# DATABASE_URL=jdbc:postgresql://db:5432/ctf
